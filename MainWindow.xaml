<Window x:Class="MusicEdge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MusicEdge"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="360"
        Height="510"
        Opacity="0.96"
        d:DesignHeight="510" d:DesignWidth="360">

    <Window.Resources>
        <!-- Premium color palette -->
        <SolidColorBrush x:Key="Surface" Color="#E60A0A1A"/>
        <SolidColorBrush x:Key="Card" Color="#12122A"/>
        <SolidColorBrush x:Key="AccentHot" Color="#FFE94560"/>
        <SolidColorBrush x:Key="TextA" Color="#FFEBEBF0"/>
        <SolidColorBrush x:Key="TextB" Color="#FF9292AA"/>
        <SolidColorBrush x:Key="TextC" Color="#FF585870"/>
        <SolidColorBrush x:Key="GlassBorder" Color="#15FFFFFF"/>

        <!-- Rich, deep gradient that stays saturated through layered-window washing -->
        <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4B3CCF" Offset="0"/>
            <GradientStop Color="#FF7C3AED" Offset="0.45"/>
            <GradientStop Color="#FFE93A6E" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SurfaceGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E60E0E24" Offset="0"/>
            <GradientStop Color="#E609091A" Offset="1"/>
        </LinearGradientBrush>

        <!-- Play triangle: refined proportions -->
        <PathGeometry x:Key="GeoPlay">M 7.5,5 L 18.5,12 L 7.5,19 Z</PathGeometry>
        <!-- Pause: two rounded bars via thick stroke -->
        <PathGeometry x:Key="GeoPause">M 8,6 L 8,18 M 15,6 L 15,18</PathGeometry>
        <!-- Next: elegant chevron + bar, stroked with round caps -->
        <PathGeometry x:Key="GeoNext">M 7,5 L 16,12 L 7,19 M 18,5 L 18,19</PathGeometry>
        <!-- Prev: mirrored chevron + bar -->
        <PathGeometry x:Key="GeoPrev">M 17,5 L 8,12 L 17,19 M 6,5 L 6,19</PathGeometry>
        <!-- Heart: flowing, organic curves -->
        <PathGeometry x:Key="GeoHeart">
            M 12,20.5 C 5,15 2,10 3,6 C 4,3 7,2 9.5,3.5
            C 11,4.5 11.5,5.5 12,7 C 12.5,5.5 13,4.5 14.5,3.5
            C 17,2 20,3 21,6 C 22,10 19,15 12,20.5 Z
        </PathGeometry>
        <!-- Shuffle: clean crossed strokes -->
        <PathGeometry x:Key="GeoShuffle">
            M 3,7 L 9,7 C 12,7 14,9 14,12
            M 21,17 L 15,17 C 12,17 10,15 10,12
            M 3,17 L 7,17 M 21,7 L 17,7
            M 14,12 L 18,12 M 10,12 L 6,12
        </PathGeometry>

        <!-- Play/Pause Button Style -->
        <Style x:Key="PlayBtn" TargetType="Button">
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Soft ambient glow behind the button -->
                            <Ellipse x:Name="ambient" Width="62" Height="62"
                                     Fill="{StaticResource BrandGradient}" Opacity="0.18">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="18"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <!-- Main button circle -->
                            <Ellipse x:Name="bg" Width="54" Height="54"
                                     Fill="{StaticResource BrandGradient}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="8"
                                                      Color="#4B3CCF" Opacity="0.55"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <!-- Subtle top highlight for 3D depth -->
                            <Ellipse Width="50" Height="26" Margin="0,-18,0,0"
                                     Fill="White" Opacity="0.08"/>
                            <!-- Icon -->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ambient" Property="Opacity" Value="0.3"/>
                                <Setter TargetName="ambient" Property="Width" Value="68"/>
                                <Setter TargetName="ambient" Property="Height" Value="68"/>
                                <Setter TargetName="bg" Property="Width" Value="58"/>
                                <Setter TargetName="bg" Property="Height" Value="58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ambient" Property="Opacity" Value="0.08"/>
                                <Setter TargetName="bg" Property="Width" Value="48"/>
                                <Setter TargetName="bg" Property="Height" Value="48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Circle Icon Button -->
        <Style x:Key="CircleBtn" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small Icon Button -->
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Progress Bar -->
        <Style x:Key="MusicProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="3"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}">
                            <Border Background="#18FFFFFF" CornerRadius="1.5"/>
                            <Border x:Name="fill" Background="{StaticResource BrandGradient}"
                                    CornerRadius="1.5" HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Glass Panel -->
    <Border CornerRadius="14,0,0,14"
            Background="{StaticResource SurfaceGradient}"
            BorderBrush="{StaticResource GlassBorder}"
            BorderThickness="1,1,0,1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="20,0,20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>    <!-- Header -->
                <RowDefinition Height="1"/>     <!-- Divider -->
                <RowDefinition Height="210"/>   <!-- Album Art -->
                <RowDefinition Height="60"/>    <!-- Track Info -->
                <RowDefinition Height="32"/>    <!-- Progress -->
                <RowDefinition Height="60"/>    <!-- Controls -->
                <RowDefinition Height="44"/>    <!-- Bottom -->
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Brand dot -->
                <Ellipse Grid.Column="0" Width="7" Height="7"
                         Fill="{StaticResource BrandGradient}" VerticalAlignment="Center">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#7C3AED" Opacity="0.8"/>
                    </Ellipse.Effect>
                </Ellipse>
                <TextBlock Grid.Column="1" Text="MusicEdge"
                           Foreground="{StaticResource TextB}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnPin" Style="{StaticResource SmallBtn}"
                            Click="BtnPin_Click" ToolTip="固定面板">
                        <TextBlock Text="📌" FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource SmallBtn}"
                            Click="BtnClose_Click" ToolTip="隐藏面板">
                        <Path Width="10" Height="10" Stretch="Uniform"
                              Stroke="{StaticResource TextB}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 0,0 L 10,10 M 10,0 L 0,10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Row 1: Divider -->
            <Border Grid.Row="1" Background="{StaticResource GlassBorder}" Margin="0,5"/>

            <!-- Row 2: Album Art -->
            <Grid Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Outer glow ring -->
                <Ellipse Width="184" Height="184"
                         Stroke="{StaticResource BrandGradient}" StrokeThickness="1.5"
                         Opacity="0.35" Fill="Transparent"/>
                <!-- Album cover -->
                <Border x:Name="AlbumFrame" Width="170" Height="170" CornerRadius="85"
                        Background="{StaticResource Card}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="8" Opacity="0.5" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <TextBlock x:Name="AlbumArtPlaceholder" Text="♫"
                                   FontSize="50" Foreground="{StaticResource TextC}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.35"/>
                        <Image x:Name="AlbumArtImage" Stretch="UniformToFill"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed">
                            <Image.Clip>
                                <EllipseGeometry RadiusX="85" RadiusY="85" Center="85,85"/>
                            </Image.Clip>
                        </Image>
                        <!-- Inner highlight ring -->
                        <Ellipse Width="170" Height="170"
                                 Stroke="#12FFFFFF" StrokeThickness="1" Fill="Transparent"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Row 3: Track Info -->
            <StackPanel Grid.Row="3" VerticalAlignment="Center" Margin="8,4">
                <TextBlock x:Name="TxtSongTitle" Text="未在播放"
                           Foreground="{StaticResource TextA}" FontSize="17"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtArtist" Text="打开 QQ 音乐开始播放"
                           Foreground="{StaticResource TextB}" FontSize="12.5"
                           TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Row 4: Progress -->
            <Grid Grid.Row="4" Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtCurrentTime" Grid.Column="0" Text="0:00"
                           Foreground="{StaticResource TextC}" FontSize="10.5"
                           FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ProgressBar x:Name="ProgressBar" Grid.Column="1"
                             Style="{StaticResource MusicProgress}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTotalTime" Grid.Column="2" Text="0:00"
                           Foreground="{StaticResource TextC}" FontSize="10.5"
                           FontFamily="Consolas" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>

            <!-- Row 5: Main Controls -->
            <StackPanel Grid.Row="5" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Style="{StaticResource CircleBtn}" Click="BtnShuffle_Click" ToolTip="随机播放">
                    <Path Width="16" Height="16" Stretch="Uniform"
                          Stroke="{StaticResource TextB}" StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round" Data="{StaticResource GeoShuffle}"/>
                </Button>
                <Button Style="{StaticResource CircleBtn}" Click="BtnPrevious_Click" ToolTip="上一首"
                        Margin="4,0,6,0">
                    <Path Width="16" Height="16" Stretch="Uniform"
                          Stroke="{StaticResource TextB}" StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round" Data="{StaticResource GeoPrev}"/>
                </Button>
                <Button x:Name="BtnPlayPause" Style="{StaticResource PlayBtn}"
                        Click="BtnPlayPause_Click" ToolTip="播放 / 暂停"
                        Margin="6,0">
                    <Path x:Name="BtnPlayPauseIcon" Width="22" Height="22" Stretch="Uniform"
                          Fill="White" Stroke="White" StrokeThickness="3.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round" Data="{StaticResource GeoPlay}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource CircleBtn}" Click="BtnNext_Click" ToolTip="下一首"
                        Margin="6,0,4,0">
                    <Path Width="16" Height="16" Stretch="Uniform"
                          Stroke="{StaticResource TextB}" StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round" Data="{StaticResource GeoNext}"/>
                </Button>
                <Button x:Name="BtnLike" Style="{StaticResource CircleBtn}"
                        Click="BtnLike_Click" ToolTip="收藏">
                    <Path x:Name="BtnLikeIcon" Width="15" Height="15" Stretch="Uniform"
                          Stroke="{StaticResource TextB}" StrokeThickness="1.6"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Fill="Transparent" Data="{StaticResource GeoHeart}"/>
                </Button>
            </StackPanel>

            <!-- Row 6: Bottom Bar -->
            <StackPanel Grid.Row="6" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Width="13" Height="13" Stretch="Uniform"
                      Stroke="{StaticResource TextC}" StrokeThickness="1.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M 2,6 L 6,3 L 10,6 M 6,3 L 6,13"/>
                <Slider x:Name="VolumeSlider" Width="68" Height="20"
                        Minimum="0" Maximum="100" Value="50"
                        ValueChanged="VolumeSlider_ValueChanged"
                        Margin="8,0,14,0"/>
                <Path Width="13" Height="13" Stretch="Uniform"
                      Stroke="{StaticResource TextC}" StrokeThickness="1.5"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M 2,6 L 6,3 L 10,6 M 6,3 L 6,13
                            M 12,9 C 13,7 13,6 12,5
                            M 14,11 C 16,8 16,5 14,3"/>
                <Button Style="{StaticResource SmallBtn}" Click="BtnPlaylist_Click"
                        ToolTip="打开 QQ 音乐" Margin="10,0,0,0">
                    <Path Width="12" Height="12" Stretch="Uniform"
                          Stroke="{StaticResource TextB}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M 4,3 L 9,6 L 4,9 Z M 3,14 L 9,7 L 15,14"/>
                </Button>
                <Button Style="{StaticResource SmallBtn}" Click="BtnSettings_Click"
                        ToolTip="设置" Margin="2,0,0,0">
                    <Path Width="12" Height="12" Stretch="Uniform"
                          Stroke="{StaticResource TextB}" StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 12,6.5 A 5.5,5.5 0 1,1 6.5,1 A 5.5,5.5 0 0,1 12,6.5 Z
                                M 12,7 A 0.6,0.6 0 1,0 12.01,7.01"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
