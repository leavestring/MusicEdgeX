<Window x:Class="MusicEdge.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MusicEdge 设置"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Width="420" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        Foreground="#EAEAEA">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E94560"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>
    </Window.Resources>

    <Border Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="⚙️ MusicEdge 设置"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#EAEAEA"
                           Margin="0,0,0,16"/>

                <!-- Adsorb position -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="📍 吸附位置"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                    <RadioButton x:Name="RbRight" Content="右侧边缘" GroupName="Edge"
                                 IsChecked="True" Foreground="#EAEAEA" FontSize="13"
                                 Margin="0,0,16,0"/>
                    <RadioButton x:Name="RbLeft" Content="左侧边缘" GroupName="Edge"
                                 Foreground="#EAEAEA" FontSize="13"/>
                </StackPanel>

                <!-- Display delays -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="⏱️ 显示延迟"/>
                <TextBlock Text="悬停展开延迟（毫秒）"/>
                <Slider x:Name="SliderHoverDelay"
                        Minimum="100" Maximum="1000" Value="300"
                        TickFrequency="50" IsSnapToTickEnabled="True"/>
                <TextBlock Text="自动隐藏延迟（毫秒）"/>
                <Slider x:Name="SliderHideDelay"
                        Minimum="200" Maximum="2000" Value="500"
                        TickFrequency="100" IsSnapToTickEnabled="True"/>
                <TextBlock Text="完全隐藏延迟（毫秒）"/>
                <Slider x:Name="SliderFullHideDelay"
                        Minimum="300" Maximum="3000" Value="800"
                        TickFrequency="100" IsSnapToTickEnabled="True"/>

                <!-- Appearance -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="🎨 外观"/>
                <CheckBox x:Name="CbEnableAcrylic" Content="启用毛玻璃效果" IsChecked="True"/>
                <CheckBox x:Name="CbUseAlbumColor" Content="跟随专辑封面变色" IsChecked="False"/>
                <CheckBox x:Name="CbDarkMode" Content="深色模式" IsChecked="True"/>

                <!-- Behavior -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="🎮 行为"/>
                <CheckBox x:Name="CbAutoStart" Content="开机自动启动"/>
                <CheckBox x:Name="CbFullscreenDisable" Content="全屏时自动禁用"
                          IsChecked="True"/>
                <CheckBox x:Name="CbMinimizeToTray" Content="关闭窗口时最小化到托盘"
                          IsChecked="True"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">
                    <Button x:Name="BtnSave"
                            Content="💾 保存" Width="100" Height="32"
                            Background="#E94560" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnSave_Click"
                            Margin="0,0,8,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnReset"
                            Content="🔄 默认" Width="100" Height="32"
                            Background="#2A2A4A" Foreground="#EAEAEA"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnReset_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
